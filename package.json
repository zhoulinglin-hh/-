{
  "name": "cet4-vocabulary-app",
  "version": "1.0.0",
  "description": "四级3500词背诵小程序 - 熟词可斩 + 词根衍生 + 近反义词 + 例句 + 易错易混 + 考频观测",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  },
  "keywords": [
    "CET4",
    "vocabulary",
    "english-learning",
    "flashcards"
  ],
  "author": "AI Assistant",
  "license": "MIT"
}
